{
  "version": 2,
  "public": true,
  "functions": {
    "api/index.php": {
      "runtime": "vercel-php@0.7.5",
      "memory": 512,
      "maxDuration": 10
    }
  },
  "env": {
    "PHP_VERSION": "8.2" 
  },
  "routes": [
    { "src": "/(.*)", "dest": "/api/index.php" }
  ],
  "outputDirectory": "public"
}